# Server Configuration
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5174

# Database
DATABASE_URL="mongodb://localhost:27017/intervox"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# OpenAI API (for AI interview questions and analysis)
OPENAI_API_KEY=your-openai-api-key-here
# Groq API (for Whisper transcription)
GROQ_API_KEY=your-groq-api-key-here

# Sarvam AI API (for Indian Text-to-Speech)
SARVAM_API_KEY=your-sarvam-api-key-here

# Anthropic API (alternative AI provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Cloud (for Speech-to-Text and Text-to-Speech)
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# AWS (Alternative for S3 storage)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=intervox-uploads

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (for notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# Websocket
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=5000

# Supabase Configuration
SUPABASE_URL=your_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key